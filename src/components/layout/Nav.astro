---
export interface Props {
  active?: 'home' | 'about' | 'log' | 'apply';
}
const { active } = Astro.props;
---
<header class="site-header">
  <div class="nav-inner">
    <a href="/" class="nav-wordmark" aria-label="Miccosukee Yacht Club home">
      <img src="/assets/crest.svg" alt="" width="40" height="40" class="nav-crest" />
      <span class="nav-wordmark-text">
        <span class="nav-wordmark-name">Miccosukee</span>
        <span class="nav-wordmark-sub">Yacht&thinsp;·&thinsp;Club</span>
      </span>
    </a>
    <nav class="primary-nav" aria-label="Primary">
      <a href="/" class={active === 'home' ? 'is-active' : ''}>Home</a>
      <a href="/about" class={active === 'about' ? 'is-active' : ''}>About</a>
      <a href="/log" class={active === 'log' ? 'is-active' : ''}>The Log</a>
      <a href="/apply" class={active === 'apply' ? 'is-active' : ''}>Apply</a>
    </nav>
    <a href="/apply" class="nav-cta">Apply for Admission</a>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: color-mix(in srgb, var(--bg-deep) 96%, transparent);
  border-bottom: 1px solid var(--border-deep);
  backdrop-filter: blur(8px);
}
.nav-inner {
  max-width: var(--container);
  margin-inline: auto;
  padding-inline: 48px;
  height: 72px;
  display: flex;
  align-items: center;
  gap: 40px;
}
.nav-wordmark {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
  text-decoration: none;
  transition: opacity var(--dur-fast) var(--ease-out);
}
.nav-wordmark:hover { opacity: 0.85; }
.nav-crest {
  flex-shrink: 0;
  /* Navy fill blends with the dark nav; brass ring and cream details remain visible */
}
.nav-wordmark-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  line-height: 1;
}
.nav-wordmark-name {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 500;
  font-style: italic;
  letter-spacing: var(--tracking-tight);
  color: var(--fg-on-deep);
}
.nav-wordmark-sub {
  font-family: var(--font-sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: var(--tracking-xwide);
  text-transform: uppercase;
  color: var(--brass-200);
}
.primary-nav {
  display: flex;
  gap: 28px;
  flex: 1;
}
.primary-nav a {
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: var(--tracking-wide);
  color: var(--fg-on-deep-muted);
  text-decoration: none;
  padding-block: 6px;
  border-bottom: 1px solid transparent;
  transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  text-transform: uppercase;
}
.primary-nav a:hover {
  color: var(--fg-on-deep);
}
.primary-nav a.is-active {
  color: var(--brass-200);
  border-bottom-color: var(--brass-500);
}
.nav-cta {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  color: var(--bg-deep);
  background: var(--brass-200);
  padding: 9px 18px;
  border-radius: var(--r-3);
  text-decoration: none;
  flex-shrink: 0;
  transition: background var(--dur-fast) var(--ease-out);
}
.nav-cta:hover { background: var(--brass-500); color: var(--sail-50); }
@media (max-width: 768px) {
  .nav-inner { padding-inline: 24px; height: auto; padding-block: 14px; flex-wrap: wrap; gap: 14px; }
  .primary-nav { order: 3; flex-basis: 100%; gap: 16px; }
  .nav-cta { display: none; }
}
</style>
