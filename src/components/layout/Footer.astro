---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-identity">
        <img src="/assets/crest.svg" alt="" width="72" height="72" />
        <div class="footer-name">Miccosukee Yacht Club</div>
        <div class="footer-tag">Est. MMXXV &middot; Lake Miccosukee, FL</div>
      </div>

      <div class="footer-col">
        <span class="footer-eyebrow">The Club</span>
        <nav>
          <a href="/about">About</a>
          <a href="/about#fleet">The Fleet</a>
          <a href="/about#commodore">The Commodore</a>
        </nav>
      </div>

      <div class="footer-col">
        <span class="footer-eyebrow">Quarters</span>
        <nav>
          <a href="/log">The Commodore's Log</a>
          <a href="/apply">Apply for Admission</a>
        </nav>
      </div>

      <div class="footer-col">
        <span class="footer-eyebrow">Make Port</span>
        <div class="footer-address">
          <span>Lake Miccosukee</span>
          <span class="footer-coords">30.4974&deg; N &middot; 84.0700&deg; W</span>
          <a href="mailto:commodore@miccosukeeyachtclub.org">commodore@miccosukeeyachtclub.org</a>
        </div>
      </div>
    </div>

    <div class="footer-ornament">
      <img src="/assets/ornament-rule.svg" alt="" height="18" />
    </div>

    <div class="footer-base">
      <span>&copy; MMXXV &middot; Miccosukee Yacht Club. All hands.</span>
      <span class="footer-motto"><em>Mare Nostrum</em></span>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--bg-deep);
  color: var(--fg-on-deep-muted);
  padding-block: var(--space-9) var(--space-7);
  border-top: 1px solid var(--border-deep);
}
.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: var(--space-8);
  align-items: start;
}
.footer-identity img {
  margin-bottom: var(--space-4);
  opacity: 0.9;
}
.footer-name {
  font-family: var(--font-display);
  font-size: 20px;
  color: var(--sail-50);
  line-height: 1.3;
}
.footer-tag {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 13px;
  color: var(--brass-200);
  margin-top: 4px;
  letter-spacing: var(--tracking-wide);
}
.footer-col .footer-eyebrow {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--fs-overline);
  font-weight: 600;
  letter-spacing: var(--tracking-xwide);
  text-transform: uppercase;
  color: var(--brass-500);
  margin-bottom: 14px;
}
.footer-col nav {
  display: grid;
  gap: 10px;
}
.footer-col nav a {
  font-family: var(--font-serif);
  font-size: 14px;
  color: var(--fg-on-deep-muted);
  text-decoration: none;
}
.footer-col nav a:hover { color: var(--fg-on-deep); }
.footer-address {
  display: grid;
  gap: 8px;
  font-family: var(--font-serif);
  font-size: 14px;
}
.footer-address a {
  color: var(--fg-on-deep-muted);
  text-decoration: none;
}
.footer-address a:hover { color: var(--brass-200); }
.footer-coords {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--fg-subtle);
}
.footer-ornament {
  display: flex;
  justify-content: center;
  margin-block: var(--space-7) var(--space-5);
  opacity: 0.4;
  filter: brightness(1.5) sepia(0.3);
}
.footer-base {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--border-deep);
  padding-top: var(--space-5);
  font-family: var(--font-sans);
  font-size: 12px;
  color: var(--fg-on-deep-muted);
  letter-spacing: var(--tracking-wide);
}
.footer-motto {
  font-family: var(--font-display);
  font-size: 15px;
  color: var(--fg-on-deep-muted);
}
@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--space-6); }
  .footer-identity { grid-column: 1 / -1; }
  .footer-base { flex-direction: column; gap: 8px; text-align: center; }
}
</style>
