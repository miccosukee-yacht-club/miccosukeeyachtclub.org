---
export interface Props {
  href?: string;
  featured?: boolean;
  class?: string;
}

const { href, featured = false, class: className = '' } = Astro.props;
---
{href ? (
  <a href={href} class={`card ${featured ? 'card-featured' : ''} card-link ${className}`}>
    <slot />
  </a>
) : (
  <div class={`card ${featured ? 'card-featured' : ''} ${className}`}>
    <slot />
  </div>
)}

<style>
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-1);
  padding: var(--space-6);
  box-shadow: var(--shadow-1);
  transition: box-shadow var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
}
.card-featured {
  border-top: 3px solid var(--brass-500);
}
.card-link {
  display: block;
  text-decoration: none;
  color: inherit;
}
.card-link:hover {
  box-shadow: var(--shadow-2);
  transform: translateY(-2px);
  color: inherit;
}
</style>
