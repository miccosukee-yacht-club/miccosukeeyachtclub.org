---
export interface Props {
  href?: string;
  variant?: 'primary' | 'accent' | 'ghost' | 'ghost-light';
  class?: string;
  external?: boolean;
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'primary',
  class: className = '',
  external = false,
  type = 'button',
} = Astro.props;

const attrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---
{href ? (
  <a href={href} class={`btn btn-${variant} ${className}`} {...attrs}>
    <slot />
  </a>
) : (
  <button type={type} class={`btn btn-${variant} ${className}`}>
    <slot />
  </button>
)}

<style>
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  padding: 11px 24px;
  border-radius: var(--r-3);
  text-decoration: none;
  border: 1px solid transparent;
  cursor: pointer;
  transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  white-space: nowrap;
}
.btn-primary {
  background: var(--navy-800);
  color: var(--fg-on-deep);
  border-color: var(--navy-800);
}
.btn-primary:hover {
  background: var(--navy-900);
  border-color: var(--navy-900);
  color: var(--fg-on-deep);
}
.btn-accent {
  background: var(--brass-500);
  color: var(--navy-900);
  border-color: var(--brass-500);
}
.btn-accent:hover {
  background: var(--brass-600);
  border-color: var(--brass-600);
  color: var(--sail-50);
}
.btn-ghost {
  background: transparent;
  color: var(--fg);
  border-color: var(--border-strong);
}
.btn-ghost:hover {
  background: var(--bg-elevated);
  color: var(--fg);
}
.btn-ghost-light {
  background: transparent;
  color: var(--fg-on-deep);
  border-color: rgba(230, 223, 207, 0.4);
}
.btn-ghost-light:hover {
  background: rgba(255, 255, 255, 0.08);
  color: var(--sail-50);
  border-color: rgba(230, 223, 207, 0.7);
}
</style>
